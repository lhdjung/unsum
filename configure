#!/usr/bin/env sh
: "${R_HOME=`R RHOME`}"

# doc-helpers.R is excluded from the build via .Rbuildignore but added to
# Collate by devtools::document(). Remove it here so R CMD INSTALL does not
# complain about a missing file.
sed -i.bak "/'doc-helpers\.R'/d" DESCRIPTION && rm -f DESCRIPTION.bak

"${R_HOME}/bin/Rscript" tools/config.R
